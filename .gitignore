cat > .gitignore << 'EOF'
# dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# env
.env
.env.*
*.env

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# build
dist/
build/
.out/
.next/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
EOF

# Local Netlify folder
.netlify
